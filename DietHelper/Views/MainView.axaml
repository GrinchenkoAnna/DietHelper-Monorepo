<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mealEntries="using:DietHelper.Common.Models.MealEntries"
             xmlns:vm="using:DietHelper.ViewModels"
             xmlns:products="using:DietHelper.Views.Products"
             xmlns:dishes="clr-namespace:DietHelper.Views.Dishes"
             xmlns:converters="clr-namespace:DietHelper.Converters"
             xmlns:mealTypes="clr-namespace:DietHelper.Common.Models.MealEntries"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="DietHelper.Views.MainView"
             x:Name="root"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Resources>
		<converters:DateStyleConverter x:Key="DateStyleConverter" />
        <converters:MealTypeToStringConverter x:Key="MealTypeToStringConverter" />   
    </UserControl.Resources>

    <UserControl.DataTemplates>
		<DataTemplate DataType="{x:Type vm:Products.UserProductViewModel}">
            <Grid ColumnDefinitions="*,25">
                <products:UserProductView Grid.Column="0" DataContext="{Binding}" HorizontalAlignment="Stretch"/>
                <Button Grid.Column="1" Content="🍽️" 
                        Classes="small-control-button" Width="25" Height="25" Margin="-5,0,0,8" VerticalAlignment="Bottom"
                        Command="{Binding $parent[UserControl].DataContext.TurnProductToReadyDishCommand}"
                        CommandParameter="{Binding}"
                        ToolTip.Tip="Это готовое блюдо">
                    <Button.Styles>						
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="BorderBrush" Value="#696969" />
                            <Setter Property="BorderThickness" Value="0.5" />
                            <Setter Property="CornerRadius" Value="5" />
                            <Setter Property="FontWeight" Value="Normal" />
                        </Style>
                    </Button.Styles>                    
                </Button>
                <Button Grid.Column="1" Content="-" Width="25" Height="25"
                        Command="{Binding $parent[UserControl].DataContext.RemoveEntryCommand}"
                        CommandParameter="{Binding}" Margin="-5,8,0,0" VerticalAlignment="Top"
                        Classes="delete-button"/>
            </Grid>			
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:Dishes.UserDishViewModel}">
			<Grid ColumnDefinitions="*, 25">
                <dishes:UserDishView Grid.Column="0" DataContext="{Binding}" HorizontalAlignment="Stretch"/>
                <Button Grid.Column="1" Content="-" Width="25" Height="25"
                        Command="{Binding $parent[UserControl].DataContext.RemoveEntryCommand}"
                        CommandParameter="{Binding}" Margin="-5,8,0,0"  VerticalAlignment="Top"
                        Classes="delete-button"/>
            </Grid>
        </DataTemplate>
    </UserControl.DataTemplates>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" 
                   HorizontalAlignment="Stretch">			
            <Button Content="Выйти" DockPanel.Dock="Left" 
                    Margin="5, 5, 0, 0" Command="{Binding LogoutCommand}"/>
            <Button Content="Сохранить день" DockPanel.Dock="Right"
                    Margin="0, 5, 5, 0" Command="{Binding SaveDayCommand}"/>
            <Button Content="Статистика" DockPanel.Dock="Right" 
                    Margin="0, 5, 5, 0" Command="{Binding OpenStatisticsCommand}"/>
        </DockPanel>

        <Border Grid.Row="1" Margin="5" Padding="5"
            Background="{DynamicResource ThemeBackgroundBrush}"
            BorderBrush="#696969"
            BorderThickness="0.5"
            CornerRadius="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"> 
            
            <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch">
				<Button Grid.Column="0" Margin="10 0 0 0" Padding="1" Content="⯇" 
                        Command="{Binding SelectPreviousWeekCommand}"
                        Width="30" HorizontalContentAlignment="Center"
                        Background="Transparent"/>

                <ItemsControl Grid.Column="1" ItemsSource="{Binding WeekDays}"
                              HorizontalAlignment="Stretch" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<UniformGrid Columns="7" Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>			
                
                    <ItemsControl.ItemTemplate>
						<DataTemplate>
							<Button Content="{Binding ., StringFormat='ddd dd.MM'}" 
                                    Command="{Binding $parent[UserControl].DataContext.SetSelectedDateCommand}"
                                    CommandParameter="{Binding .}"
                                    Classes="day-button">
                                <Button.Tag>
                                    <MultiBinding Converter="{StaticResource DateStyleConverter}">
                                        <Binding Path="."/>
                                        <Binding Path="$parent[UserControl].DataContext.SelectedDate"/>
                                    </MultiBinding>
                                </Button.Tag>
                            </Button>
                        </DataTemplate> 
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

				<Button Grid.Column="2" Margin="0 0 10 0" Padding="1" Content="⯈" 
                        Command="{Binding SelectNextWeekCommand}"
                        Width="30" HorizontalContentAlignment="Center"
                        Background="Transparent"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">            
            <StackPanel>
                <Border Background="{StaticResource MealBreakfastBackground}" CornerRadius="4" Padding="8,2" 
                        HorizontalAlignment="Left" Margin="10,12,16,2">
                    <TextBlock Text="ЗАВТРАК" FontWeight="SemiBold" FontSize="12" 
                               Foreground="{StaticResource MealBreakfastColor}"/>
                </Border>
                <ListBox ItemsSource="{Binding BreakfastEntries}" Background="Transparent" 
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Grid ColumnDefinitions="*,*" HorizontalAlignment="Stretch" Margin="5">
                    <Button Grid.Column="0" Content="+ продукт" Classes="add-control-button"
                            Height="20" HorizontalAlignment="Center" Padding="10, 0, 10, 0"
                            Command="{Binding AddUserProductCommand}" Margin="5,0,5,0"
                            CommandParameter="{x:Static mealEntries:MealType.Breakfast}"/>
                    <Button Grid.Column="1" Content="+ блюдо" Classes="add-control-button"
                            Height="20" HorizontalAlignment="Center" Padding="10, 0, 10, 0"
                            Command="{Binding AddDishCommand}" Margin="5,0,5,0"
                            CommandParameter="{x:Static mealEntries:MealType.Breakfast}"/>
                </Grid>

                <Border Background="{StaticResource MealLunchBackground}" CornerRadius="4" Padding="8,2" 
                        HorizontalAlignment="Left" Margin="10,12,16,2">
                    <TextBlock Text="ОБЕД" FontWeight="SemiBold" FontSize="12" 
                               Foreground="{StaticResource MealLunchColor}"/>
                </Border>
                <ListBox ItemsSource="{Binding LunchEntries}" Background="Transparent" 
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Grid ColumnDefinitions="*,*" HorizontalAlignment="Stretch" Margin="5">
                    <Button Grid.Column="0" Content="+ продукт" Classes="add-control-button"
                            Height="20" HorizontalAlignment="Center" Padding="10, 0, 10, 0"
                            Command="{Binding AddUserProductCommand}" Margin="5,0,5,0"
                            CommandParameter="{x:Static mealEntries:MealType.Lunch}"/>
                    <Button Grid.Column="1" Content="+ блюдо" Classes="add-control-button"
                            Height="20" HorizontalAlignment="Center" Padding="10, 0, 10, 0"
                            Command="{Binding AddDishCommand}" Margin="5,0,5,0"
                            CommandParameter="{x:Static mealEntries:MealType.Lunch}"/>
                </Grid>

                <Border Background="{StaticResource MealDinnerBackground}" CornerRadius="4" Padding="8,2" 
                        HorizontalAlignment="Left" Margin="10,12,16,2">
                    <TextBlock Text="УЖИН" FontWeight="SemiBold" FontSize="12" 
                                Foreground="{StaticResource MealDinnerColor}"/>
                </Border>
                <ListBox ItemsSource="{Binding DinnerEntries}" Background="Transparent" 
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Grid ColumnDefinitions="*,*" HorizontalAlignment="Stretch" Margin="5">
                    <Button Grid.Column="0" Content="+ продукт" Classes="add-control-button"
                            Height="20" HorizontalAlignment="Center" Padding="10, 0, 10, 0"
                            Command="{Binding AddUserProductCommand}" Margin="5,0,5,0"
                            CommandParameter="{x:Static mealEntries:MealType.Dinner}"/>
                    <Button Grid.Column="1" Content="+ блюдо" Classes="add-control-button"
                            Height="20" HorizontalAlignment="Center" Padding="10, 0, 10, 0"
                            Command="{Binding AddDishCommand}" Margin="5,0,5,0"
                            CommandParameter="{x:Static mealEntries:MealType.Dinner}"/>
                </Grid>

                <Border Background="{StaticResource MealSnackBackground}" CornerRadius="4" Padding="8,2" 
                        HorizontalAlignment="Left" Margin="10,12,16,2">
                    <TextBlock Text="ПЕРЕКУС" FontWeight="SemiBold" FontSize="12" 
                               Foreground="{StaticResource MealSnackColor}"/>
                </Border>
                <ListBox ItemsSource="{Binding SnackEntries}" Background="Transparent" 
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Grid ColumnDefinitions="*,*" HorizontalAlignment="Stretch" Margin="5">
                    <Button Grid.Column="0" Content="+ продукт" Classes="add-control-button"
                            Height="20" HorizontalAlignment="Center" Padding="10, 0, 10, 0"
                            Command="{Binding AddUserProductCommand}" Margin="5,0,5,0"
                            CommandParameter="{x:Static mealEntries:MealType.Snack}"/>
                    <Button Grid.Column="1" Content="+ блюдо" Classes="add-control-button"
                            Height="20" HorizontalAlignment="Center" Padding="10, 0, 10, 0"
                            Command="{Binding AddDishCommand}" Margin="5,0,5,0"
                            CommandParameter="{x:Static mealEntries:MealType.Snack}"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3" Padding="10,10,26,10" Margin="10" 
                CornerRadius="3" BorderThickness="1" 
                Background="{DynamicResource ThemeBackgroundBrush}"
                BorderBrush="#696969">
            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*,Auto,*,Auto,*,25" HorizontalAlignment="Stretch">
                <TextBlock Grid.Column="0" Text="К:" FontWeight="Medium" Margin="5,5,0,5" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="1" Text="{Binding TotalNutrition.FormattedCalories}" 
                           Margin="5,5,0,5" HorizontalAlignment="Left"/>

                <TextBlock Grid.Column="2" Text="Б:" FontWeight="Medium" Margin="5,5,0,5" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="3" Text="{Binding TotalNutrition.FormattedProtein}" 
                           Margin="5,5,0,5" HorizontalAlignment="Left"/>

                <TextBlock Grid.Column="4" Text="Ж:" FontWeight="Medium" Margin="5,5,0,5" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="5" Text="{Binding TotalNutrition.FormattedFat}" 
                           Margin="5,5,0,5" HorizontalAlignment="Left"/>

                <TextBlock Grid.Column="6" Text="У:" FontWeight="Medium" Margin="5,5,0,5" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="7" Text="{Binding TotalNutrition.FormattedCarbs}" 
                           Margin="5,5,0,5" HorizontalAlignment="Left"/>

                <TextBlock Grid.Column="8" Text="Вес:" FontWeight="Medium" Margin="5,5,0,5" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="9" Text="{Binding FormattedTotalQuantity}" 
                           Margin="15,5,0,5" HorizontalAlignment="Left"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
