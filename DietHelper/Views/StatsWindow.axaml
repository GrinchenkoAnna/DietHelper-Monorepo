<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:DietHelper.ViewModels"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="DietHelper.Views.StatsWindow"
        Title="StatsWindow"
        x:DataType="vm:StatsViewModel">
  
    <StackPanel>        
        <Button Content="Загрузить данные" Command="{Binding LoadStatsCommand}"/>

        <lvc:CartesianChart Series="{Binding NutritionSeries}"
                            XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"
                            Height="300"/>

        <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
            <TextBlock Grid.Column="0" Grid.Row="0" Text="start"/>
            <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding StartDay}"/>
            <TextBlock Grid.Column="0" Grid.Row="1" Text="end"/>

            <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding EndDay}"/>
		    <TextBlock Grid.Column="0" Grid.Row="2" Text="К" />
		    <TextBlock Grid.Column="1" Grid.Row="2" Text="{Binding TotalNutrition.Calories}" />
		    <TextBlock Grid.Column="0" Grid.Row="3" Text="Б" />
		    <TextBlock Grid.Column="1" Grid.Row="3" Text="{Binding TotalNutrition.Protein}" />
		    <TextBlock Grid.Column="0" Grid.Row="4" Text="Ж" />
		    <TextBlock Grid.Column="1" Grid.Row="4" Text="{Binding TotalNutrition.Fat}" />
		    <TextBlock Grid.Column="0" Grid.Row="5" Text="У" />
		    <TextBlock Grid.Column="1" Grid.Row="5" Text="{Binding TotalNutrition.Carbs}" />

            <ListBox Grid.Row="6" x:Name="nutritions" 
                     ItemsSource="{Binding Nutritions}"
                     Background="Transparent"
                     BorderThickness="0"
                     CornerRadius="8">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Background" Value="{DynamicResource IngredientBackground}"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Padding" Value="0,2"/>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource IngredientBackground}"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Padding" Value="0,2"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid RowDefinitions="Auto, Auto" Margin="0,2">

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                <TextBlock Text="К:" FontWeight="Medium" Margin="5,5,0,5"/>
                                <TextBlock Text="{Binding FormattedCalories}" 
                                           Width="100" FontWeight="Medium" Margin="5,5,0,5"/>

                                <TextBlock Text="Б:" FontWeight="Medium" Margin="5,5,0,5"/>
                                <TextBlock Text="{Binding FormattedProtein}" 
                                           Width="100" FontWeight="Medium" Margin="5,5,0,5"/>

                                <TextBlock Text="Ж:" FontWeight="Medium" Margin="5,5,0,5"/>
                                <TextBlock Text="{Binding FormattedFat}" 
                                           Width="100" FontWeight="Medium" Margin="5,5,0,5"/>

                                <TextBlock Text="У:" FontWeight="Medium" Margin="5,5,0,5"/>
                                <TextBlock Text="{Binding FormattedCarbs}" 
                                           Width="100" FontWeight="Medium" Margin="5,5,0,5"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
			
        </Grid>
    </StackPanel>

</Window>
