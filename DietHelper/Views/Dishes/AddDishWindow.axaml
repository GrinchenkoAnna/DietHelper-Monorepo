<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DietHelper.ViewModels.Dishes"
        xmlns:local="clr-namespace:DietHelper.Views.Dishes"
		xmlns:manual="clr-namespace:DietHelper.Views"
		xmlns:converters="clr-namespace:DietHelper.Converters"
        mc:Ignorable="d"
        x:Class="DietHelper.Views.Dishes.AddDishWindow"
        Title="Добавить блюдо" Height="600" Width="900" MinWidth="900"
        x:DataType="vm:AddUserDishViewModel"
        WindowStartupLocation="CenterScreen">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Margin="0 5 0 0">
			<TextBox Watermark="Поиск блюда"
                     Text="{Binding SearchText, Delay=400}"/>
			<ProgressBar IsIndeterminate="True"
                        IsVisible="{Binding IsBusy}"/>
		</StackPanel>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,21,0">
            <ListBox ItemsSource="{Binding UserSearchResults}"
                     SelectedItem="{Binding SelectedUserItem}"
                     HorizontalAlignment="Stretch">
                <ListBox.Styles>
                    <Style Selector="ListBox">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                    </Style>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*, Auto" HorizontalAlignment="Stretch">
                            <local:UserDishView Grid.Column="0" HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="1" Content="🗑" Width="25" Height="25" Margin="-5,8,0,0"
                                    Command="{Binding $parent[Window].DataContext.DeleteItemFromDatabaseCommand}"
                                    CommandParameter="{Binding}"
                                    HorizontalAlignment="Center" VerticalAlignment="Top"
                                    Classes="small-control-button"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

		<Button Grid.Row="2"
                Content="Добавить блюдо"
                Command="{Binding AddUserItemCommand}"
                HorizontalAlignment="Center"
                Margin="0 5 0 5"
				Classes="control-button"/>

		<manual:AddDishManuallyView Grid.Row="3" Grid.ColumnSpan="2" />

		<Button Grid.Row="4"
                Content="Создать блюдо"
                Command="{Binding AddManualItemCommand}"
                HorizontalAlignment="Center"
                Margin="0 5 0 10"
				Classes="control-button"/>	
		
		<StackPanel Grid.Row="4" Grid.Column="1" 
			  Orientation="Horizontal"
			  HorizontalAlignment="Right"
			  VerticalAlignment="Stretch"
			  Margin="0 0 10 0">
			 <RadioButton GroupName="DishType"
                       Content="Пустое блюдо"
                       IsChecked="{Binding IsEmptyDish}"/>
            <RadioButton GroupName="DishType"
                       Content="Готовое блюдо (100 г.)"
                       IsChecked="{Binding IsReadyDish}"
                       Margin="10,0,0,0"/>
		</StackPanel>	
	</Grid>
</Window>