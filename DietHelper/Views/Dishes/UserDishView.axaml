<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ingredients="clr-namespace:DietHelper.Views.Products"
             xmlns:vm="clr-namespace:DietHelper.ViewModels.Dishes"
             xmlns:dishes="clr-namespace:DietHelper.Views.Dishes"
             xmlns:converters="clr-namespace:DietHelper.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="DietHelper.Views.Dishes.UserDishView"
             x:DataType="vm:UserDishViewModel" x:Name="Root">

    <UserControl.Resources>
		<converters:BorderThicknessForDishConverter x:Key="BorderThicknessForDishConverter"/>
		<converters:BoolToArrowConverter x:Key="BoolToArrowConverter"/>
		<converters:BoolToDoubleConverter x:Key="BoolToDoubleConverter"/>
    </UserControl.Resources>

    <Border Background="{DynamicResource CardBackground}"
            CornerRadius="8"
            Margin="10,5"
            Padding="12,8"
            MinWidth="773">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" 
                              Color="{DynamicResource CardShadowColor}" 
                              OffsetX="0" OffsetY="2" 
                              Opacity="1"/>
        </Border.Effect>
        <Grid RowDefinitions="Auto, Auto, Auto, *">
            <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto, *, Auto, Auto">
                <TextBlock Grid.Column="0" Text="{Binding Name}" 
                           FontWeight="SemiBold" FontSize="16" TextWrapping="Wrap"/>
                <TextBlock Grid.Column="1" Text=" • изменено" 
                           Foreground="Gray" FontSize="12" IsVisible="{Binding ShowDirtyIndicator}"/>
                <Button Grid.Column="3" Content="+" 
                        HorizontalContentAlignment="Center" HorizontalAlignment="Stretch" 
                        Command="{Binding AddDishIngredientCommand}"
                        IsEnabled="{Binding CanAddIngredients}"
                        IsVisible="{Binding CanAddIngredients}"
                        Margin="0,0,5,0" Width="25" Height="25"
                        ToolTip.Tip="Добавить ингредиент"
                        Classes="small-control-button"/>
                <ToggleButton Grid.Column="4" IsChecked="{Binding ShowIngredients}" 
                              Content="{Binding ShowIngredients, Converter={StaticResource BoolToArrowConverter}}"
                              HorizontalAlignment="Stretch" 
                              Margin="0,0,5,0" Width="30" Height="25"
                              Classes="show-ingredient"
                              IsVisible="{Binding !IsReadyDish}"
                              IsEnabled="{Binding !IsReadyDish}"/>
            </Grid>

            <TextBlock Grid.Row="1" 
                       Text="Готовое блюдо" 
                       FontSize="10" 
                       Foreground="Gray"
                       IsVisible="{Binding IsReadyDish}"/>

            <StackPanel Grid.Row="2" Margin="0,6,0,8">
                <Border Background="Transparent"
                        BorderBrush="Gray"
                        BorderThickness="{Binding IsReadyDish, Converter={StaticResource BorderThicknessForDishConverter}}">
                    <StackPanel>
						<TextBlock Text="Пищевая ценность всего блюда:" />
                        <TextBlock Text="Для пересчета КБЖУ измените вес блюда" 
                                   FontSize="10" Foreground="Gray"
                                   IsVisible="{Binding IsReadyDish}"/>

                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left" Margin="0,4,0,0">        
                            <TextBlock Text="К:" FontWeight="Medium" Margin="5,5,0,5"/>
                            <TextBlock Text="{Binding NutritionFacts.FormattedCalories}" 
                                       Width="100" Margin="5,5,0,5"/>

                            <TextBlock Text="Б:" FontWeight="Medium" Margin="5,5,0,5"/>
                            <TextBlock Text="{Binding NutritionFacts.FormattedProtein}" 
                                       Width="100" Margin="5,5,0,5"/>

                            <TextBlock Text="Ж:" FontWeight="Medium" Margin="5,5,0,5"/>
                            <TextBlock Text="{Binding NutritionFacts.FormattedFat}" 
                                       Width="100" Margin="5,5,0,5"/>

                            <TextBlock Text="У:" FontWeight="Medium" Margin="5,5,0,5"/>
                            <TextBlock Text="{Binding NutritionFacts.FormattedCarbs}" 
                                       Width="100" Margin="5,5,0,5"/>

                            <TextBlock Text="Вес:" FontWeight="Medium" Margin="5,5,0,5"/>
                            <TextBox Text="{Binding Quantity}" 
                                     Width="100" Margin="5,0,0,0"
                                     Background="Transparent"
                                     IsVisible="{Binding IsReadyDish}"/>
                            <TextBlock Text="{Binding FormattedQuantity}" 
                                       Width="100" Margin="5,5,0,5"
                                       IsVisible="{Binding !IsReadyDish}"/>
                        </StackPanel>
                    </StackPanel>			
                </Border>                
            </StackPanel>

            <ListBox Grid.Row="3" x:Name="ingredientsList" 
                     ItemsSource="{Binding Ingredients}"
                     Background="Transparent"
                     BorderThickness="0"
                     CornerRadius="8"
                     Margin="0,0,-5,-5"
                     IsVisible="{Binding ShowIngredients}">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Background" Value="{DynamicResource IngredientBackground}"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Padding" Value="0,2"/>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource IngredientBackground}"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Padding" Value="0,2"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid RowDefinitions="Auto, Auto" Margin="0,2">
                            <TextBlock Grid.Row="0" Text="{Binding ProductNameSnapshot}" 
                                       FontWeight="Medium" FontSize="14" 
                                       Margin="5,5,0,2"/>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                <TextBlock Text="К:" FontWeight="Medium" Margin="5,5,0,5"/>
                                <TextBlock Text="{Binding CurrentNutrition.FormattedCalories}" 
                                           Width="100" FontWeight="Medium" Margin="5,5,0,5"/>

                                <TextBlock Text="Б:" FontWeight="Medium" Margin="5,5,0,5"/>
                                <TextBlock Text="{Binding CurrentNutrition.FormattedProtein}" 
                                           Width="100" FontWeight="Medium" Margin="5,5,0,5"/>

                                <TextBlock Text="Ж:" FontWeight="Medium" Margin="5,5,0,5"/>
                                <TextBlock Text="{Binding CurrentNutrition.FormattedFat}" 
                                           Width="100" FontWeight="Medium" Margin="5,5,0,5"/>

                                <TextBlock Text="У:" FontWeight="Medium" Margin="5,5,0,5"/>
                                <TextBlock Text="{Binding CurrentNutrition.FormattedCarbs}" 
                                           Width="100" FontWeight="Medium" Margin="5,5,0,5"/>

                                <TextBlock Text="Вес:" FontWeight="Medium" Margin="5,5,0,5"/>
                                <TextBox Text="{Binding Quantity}" 
                                         Width="100" 
                                         Margin="5,0,0,0"
                                         Background="Transparent"/>

                                <Button Content="-" Width="20" Margin="0,0,5,1"
                                        Command="{Binding $parent[dishes:UserDishView].DataContext.RemoveIngredientCommand, FallbackValue={x:Null}}"
                                        CommandParameter="{Binding}"
                                        Classes="control-button"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</UserControl>