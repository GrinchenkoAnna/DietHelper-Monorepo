<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DietHelper.App"
             xmlns:local="using:DietHelper"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <Style Selector="Button.control-button">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderBrush" Value="#696969" />
			<Setter Property="BorderThickness" Value="0.5" />
			<Setter Property="CornerRadius" Value="3" />
			<Setter Property="FontWeight" Value="Light" />
			<Setter Property="MinWidth" Value="25" />
        </Style>
        <Style Selector="Button.control-button:pointerover /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="#696969"/>
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="FontWeight" Value="Light" />
			<Setter Property="MinWidth" Value="25" />
        </Style>
    </Application.Styles>

    <Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>
				<ResourceDictionary x:Key="Light">
                <SolidColorBrush x:Key="CardBackground" Color="#EEEEEE"/>
                <SolidColorBrush x:Key="IngredientBackground" Color="#DDDDDD"/>
                <Color x:Key="CardShadowColor">#30000000</Color>
            </ResourceDictionary>
            <ResourceDictionary x:Key="Dark">
                <SolidColorBrush x:Key="CardBackground" Color="#222222"/>
                <SolidColorBrush x:Key="IngredientBackground" Color="#111111"/>
                <Color x:Key="CardShadowColor">#70FFFFFF</Color>
            </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>